{
	"name": "fw-fanctrl-revived-gnome-shell-extension",
	"private": true,
	"type": "module",
	"main": "src/index.ts",
	"scripts": {
		"build": "tsup-node",
		"check": "prettier --check . && biome check . && tsc --noEmit",
		"fix": "prettier --write . && biome check --write ."
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.8",
		"@girs/gjs": "4.0.0-beta.40",
		"@girs/gnome-shell": "^49.1.0",
		"@types/node": "^25.5.0",
		"prettier": "^3.8.1",
		"tinyexec": "^1.0.4",
		"tsup": "^8.5.1",
		"typescript": "^5.9.3"
	},
	"packageManager": "pnpm@10.32.1",
	"pnpm": {
		"onlyBuiltDependencies": [
			"@biomejs/biome",
			"esbuild"
		]
	}
}
